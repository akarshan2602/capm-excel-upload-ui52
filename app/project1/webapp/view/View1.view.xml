<mvc:View
    controllerName="excelupload.project1.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:u="sap.ui.unified">

    <Page title="Generic Excel Upload">

        <content>

            <VBox class="sapUiSmallMargin">

                <u:FileUploader
                    id="fileUploader"
                    fileType="xlsx"
                    width="400px"
                    change="onFileUpload"/>

                <Button
                    text="Submit Selected Rows"
                    press="onSubmit"
                    class="sapUiSmallMarginTop"/>
                    <!-- BUTTON FOR DOWNLOADING ERROR REPORT     -->
                <Button
                    text="Download Error Report"
                    press="onDownloadErrorReport"
                    class="sapUiSmallMarginTop"/>

                <HBox
                    justifyContent="SpaceAround"
                    class="sapUiSmallMarginTop sapUiSmallMarginBottom">

                    <ObjectStatus
                        title="Total"
                        text="{excel>/summary/total}"/>

                    <ObjectStatus
                        title="Valid"
                        text="{excel>/summary/valid}"/>

                    <ObjectStatus
                        title="Invalid"
                        text="{excel>/summary/invalid}"/>

                    <ObjectStatus
                        title="Excel Duplicate"
                        text="{excel>/summary/duplicate}"/>

                    <ObjectStatus
                        title="DB Duplicate"
                        text="{excel>/summary/dbDuplicates}"/>

                </HBox>

                <Table
                    id="idTable"
                    mode="MultiSelect">
                </Table>

            </VBox>

        </content>

    </Page>

</mvc:View>